{
    "name": "mirrorps/drupal-taler-payments",
    "description": "Custom Drupal module integrating GNU Taler payments via the TalerPHP SDK.",
    "type": "drupal-custom-module",
    "license": "GPL-2.0-or-later",
    "keywords": ["drupal", "payments", "taler"],
    "require": {
        "php": ">=8.1",
        "ext-openssl": "*",
        "mirrorps/taler-php": "~1.2.0"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest"
    },
    "extra": {
        "installer-name": "taler_payments"
    },
    "autoload": {
        "psr-4": {
            "Drupal\\taler_payments\\": "src/"
        }
    }
}
